# fzf
source <(fzf --zsh)

# configuration
HISTSIZE=100000
SAVEHIST=100000

# ppap スクリプト
function ezip() {
  local file_name="${1:?ファイル名を指定してください}"
  local base_name="${file_name%.*}"
  local zip_file="${base_name}.zip"
  local pass="$(LC_ALL=C tr -dc 'A-Za-z0-9!"#$%&'\''()*+,-./:;<=>?@[\]^_`{|}~' </dev/urandom | head -c 16)"
  local file="KCI-$(date '+%Y%m%d%H%M%S').zip"
  zip -P "$pass" -9r "$zip_file" "$@"
  echo "パスワードは\n\n$pass\n\nです。\n\n以上、よろしくお願いします"
}

# ranger 終了時にカレントディレクトリ位置を保持
alias ranger='ranger --choosedir=$HOME/.rangerdir; LASTDIR=`cat $HOME/.rangerdir`; cd "$LASTDIR"'

# 動画変換
function mov2mp4() {
    if [[ -z "$1" ]]; then
        echo "Usage: mov2mp4 <inputfile>"
        return 1
    fi
    inputfile="$1"
    outputfile="${inputfile%.*}.mp4"
    
    if [[ -f "$inputfile" ]]; then
        ffmpeg -i "$inputfile" -vcodec libx264 -acodec aac "$outputfile"
        echo "Converted: $outputfile"
    else
        echo "Error: File '$inputfile' not found."
        return 1
    fi
}

# 動画からwav抽出
function mov2wav() {
    if [[ -z "$1" ]]; then
        echo "Usage: mov2wav <inputfile>"
        return 1
    fi
    inputfile="$1"
    outputfile="${inputfile%.*}.wav"
    
    if [[ -f "$inputfile" ]]; then
        # ffmpeg -i "$inputfile" -vcodec libx264 -acodec aac "$outputfile"
        ffmpeg -i "$inputfile" -vn -acodec pcm_s16le -ar 44100 -ac 2 "$outputfile"
        echo "Converted: $outputfile"
    else
        echo "Error: File '$inputfile' not found."
        return 1
    fi
}

# SSH Agentを起動し、環境変数を設定
if [ -z "$SSH_AUTH_SOCK" ]; then
    eval "$(ssh-agent -s)"
fi
# 秘密鍵を ssh-agent に登録
# (新しいセッションでは引き継がれないので毎回登録)
if [[ -f "$HOME/.ssh/id_rsa" ]]; then
  ssh-add "$HOME/.ssh/id_rsa" > /dev/null 2>&1
fi

export EDITOR='vim'
export VISUAL='vim'

